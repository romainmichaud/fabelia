# ============================================================
# Mon Livre — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# ——— Supabase ———————————————————————————————————————————————
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ——— App ————————————————————————————————————————————————————
NEXT_PUBLIC_BASE_URL=http://localhost:3001

# ——— OpenAI ————————————————————————————————————————————————
OPENAI_API_KEY=sk-...

# ——— Stripe ————————————————————————————————————————————————
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in your Stripe dashboard
STRIPE_PRICE_DIGITAL=price_...
STRIPE_PRICE_BUNDLE=price_...
STRIPE_PRICE_PRINT_SOFTCOVER=price_...
STRIPE_PRICE_PRINT_HARDCOVER=price_...

# ——— PayPal ————————————————————————————————————————————————
PAYPAL_CLIENT_ID=your-client-id
PAYPAL_CLIENT_SECRET=your-client-secret
# Use https://api-m.paypal.com for production
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_WEBHOOK_ID=your-webhook-id

# ——— Admin ————————————————————————————————————————————————
# Secret used to authorize manual generation triggers
ADMIN_SECRET=change-me-to-a-long-random-string

# ——— Print Provider ——————————————————————————————————————
# Options: mock (default), printful, mimeo, lulu
PRINT_PROVIDER=mock

# ——— Storage ————————————————————————————————————————————
# Supabase Storage bucket names (create these in your project)
SUPABASE_STORAGE_BUCKET_BOOKS=books
SUPABASE_STORAGE_BUCKET_COVERS=covers
SUPABASE_STORAGE_BUCKET_EXPORTS=exports
